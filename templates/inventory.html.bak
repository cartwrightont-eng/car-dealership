 {% extends "base.html" %}
{% block title %}Inventory — Apex Motors Kenya{% endblock %}
{% block meta_description %}Browse {{ cars.total }} quality pre-owned vehicles at Apex Motors Kenya. SUVs, Sedans, Pickups, Hybrids. Competitive prices, financing available. Nairobi, Kenya.{% endblock %}
{% block og_title %}Car Inventory — Apex Motors Kenya{% endblock %}
{% block og_description %}Browse quality pre-owned vehicles in Nairobi. SUVs, Sedans, Pickups and more. Financing available at Apex Motors Kenya.{% endblock %}
{% block twitter_title %}Car Inventory — Apex Motors Kenya{% endblock %}
{% block twitter_description %}Browse quality pre-owned vehicles in Nairobi. Financing available.{% endblock %}
{% block extra_css %}
<style>
/* ── SKELETON SCREENS ── */
.skeleton { background: linear-gradient(90deg, #1a1a2e 25%, #2a2a3e 50%, #1a1a2e 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
.skeleton-card { background: var(--card-bg, #111); border-radius: 12px; overflow: hidden; }
.skeleton-img { height: 200px; width: 100%; }
.skeleton-body { padding: 16px; display: flex; flex-direction: column; gap: 10px; }
.skeleton-line { height: 14px; border-radius: 4px; }
.skeleton-line.short { width: 40%; }
.skeleton-line.medium { width: 65%; }
.skeleton-line.long { width: 90%; }
.skeleton-price { height: 20px; width: 50%; border-radius: 4px; margin-top: 8px; }
.car-grid-skeleton { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
@media (max-width: 900px) { .car-grid-skeleton { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .car-grid-skeleton { grid-template-columns: 1fr; } }

/* ── ERROR TOAST ── */
.error-toast { position: fixed; bottom: 24px; right: 24px; background: #1a1a1a; border: 1px solid #e74c3c; border-left: 4px solid #e74c3c; border-radius: 8px; padding: 16px 20px; max-width: 360px; z-index: 9999; display: flex; align-items: flex-start; gap: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.4); transform: translateX(120%); transition: transform 0.3s ease; }
.error-toast.show { transform: translateX(0); }
.error-toast-icon { font-size: 18px; flex-shrink: 0; margin-top: 2px; }
.error-toast-body { flex: 1; }
.error-toast-title { font-weight: 600; color: #e74c3c; font-size: 14px; margin-bottom: 4px; }
.error-toast-msg { color: rgba(255,255,255,0.7); font-size: 13px; line-height: 1.4; }
.error-toast-close { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; font-size: 18px; padding: 0; flex-shrink: 0; }
.error-toast-close:hover { color: #fff; }

/* ── SIMULATE BUTTON (dev only) ── */
.sim-bar { background: #1a1a2e; border-bottom: 1px solid #2a2a3e; padding: 8px 24px; display: flex; gap: 12px; align-items: center; font-size: 13px; color: rgba(255,255,255,0.5); }
.sim-btn { background: #2a2a3e; border: 1px solid #3a3a4e; color: #fff; padding: 4px 12px; border-radius: 4px; cursor: pointer; font-size: 12px; }
.sim-btn:hover { background: #3a3a4e; }
</style>
{% endblock %}
{% block content %}
<div class="inventory-page">

  <div class="sim-bar">
    <span>🛠 Dev tools:</span>
    <button class="sim-btn" onclick="simulateSkeleton()">Show Skeleton</button>
    <button class="sim-btn" onclick="showError('network')">Network Error</button>
    <button class="sim-btn" onclick="showError('server')">Server Error</button>
    <button class="sim-btn" onclick="showError('ratelimit')">Rate Limit</button>
    <button class="sim-btn" onclick="showError('notfound')">Not Found</button>
  </div>

  <!-- PAGE HEADER -->

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="page-header-inner">
      <h1>Browse Inventory</h1>
      <p>{{ cars.total }} vehicles available. Inspected, certified, ready to drive.</p>
    </div>
  </div>

  <div class="inventory-layout">

    <!-- SIDEBAR FILTERS -->
    <aside class="filter-sidebar">
      <div class="filter-header">
        <h3>Filter Vehicles</h3>
        <a href="{{ url_for('inventory') }}" class="filter-clear">Clear All</a>
      </div>
      <form method="GET" action="{{ url_for('inventory') }}" id="filterForm">

        <div class="filter-group">
          <label>Make</label>
          <select name="make">
            <option value="">All Makes</option>
            {% for make in makes %}
            <option value="{{ make }}" {% if filters.make == make %}selected{% endif %}>{{ make }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="filter-group">
          <label>Body Type</label>
          <select name="body_type">
            <option value="">All Types</option>
            {% for bt in ['SUV', 'Sedan', 'Hatchback', 'Pickup', 'Van', 'Coupe'] %}
            <option value="{{ bt }}" {% if filters.body_type == bt %}selected{% endif %}>{{ bt }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="filter-group">
          <label>Fuel Type</label>
          <select name="fuel_type">
            <option value="">All Fuels</option>
            {% for ft in ['Petrol', 'Diesel', 'Hybrid', 'Electric'] %}
            <option value="{{ ft }}" {% if filters.fuel_type == ft %}selected{% endif %}>{{ ft }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="filter-group">
          <label>Transmission</label>
          <select name="transmission">
            <option value="">All</option>
            <option value="Automatic" {% if filters.transmission == 'Automatic' %}selected{% endif %}>Automatic</option>
            <option value="Manual" {% if filters.transmission == 'Manual' %}selected{% endif %}>Manual</option>
          </select>
        </div>

        <div class="filter-group">
          <label>Price Range (KES)</label>
          <select name="max_price">
            <option value="99999999">Any Budget</option>
            <option value="1500000" {% if filters.max_price == 1500000 %}selected{% endif %}>Under 1.5M</option>
            <option value="2500000" {% if filters.max_price == 2500000 %}selected{% endif %}>Under 2.5M</option>
            <option value="4000000" {% if filters.max_price == 4000000 %}selected{% endif %}>Under 4M</option>
            <option value="6000000" {% if filters.max_price == 6000000 %}selected{% endif %}>Under 6M</option>
            <option value="9000000" {% if filters.max_price == 9000000 %}selected{% endif %}>Under 9M</option>
          </select>
        </div>

        <div class="filter-group">
          <label>Year From</label>
          <select name="min_year">
            {% for y in range(2024, 2009, -1) %}
            <option value="{{ y }}" {% if filters.min_year == y %}selected{% endif %}>{{ y }}</option>
            {% endfor %}
            <option value="2000" {% if filters.min_year == 2000 %}selected{% endif %}>Any Year</option>
          </select>
        </div>

        <button type="submit" class="btn btn-primary filter-apply">Apply Filters</button>
      </form>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="inventory-main">
      <div class="inventory-toolbar">
        <span class="result-count">{{ cars.total }} results</span>
        <form method="GET" action="{{ url_for('inventory') }}" class="sort-form">
          <!-- preserve other filters -->
          {% for k, v in filters.items() %}
            {% if k != 'sort' and v %}
            <input type="hidden" name="{{ k }}" value="{{ v }}">
            {% endif %}
          {% endfor %}
          <select name="sort" onchange="this.form.submit()" class="sort-select">
            <option value="newest" {% if filters.sort == 'newest' %}selected{% endif %}>Newest First</option>
            <option value="price_asc" {% if filters.sort == 'price_asc' %}selected{% endif %}>Price: Low to High</option>
            <option value="price_desc" {% if filters.sort == 'price_desc' %}selected{% endif %}>Price: High to Low</option>
            <option value="year_desc" {% if filters.sort == 'year_desc' %}selected{% endif %}>Year: Newest</option>
          </select>
        </form>
      </div>

      {% if cars.items %}
      <div class="car-grid car-grid-3">
        {% for car in cars.items %}
        <a href="{{ url_for('car_detail', car_id=car.id) }}" class="car-card">
          <div class="car-card-img-wrap">
            <img src="{{ (car.images | fromjson)[0] if car.images else 'https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=600&q=80' }}"
                 alt="{{ car.year }} {{ car.make }} {{ car.model }}" class="car-card-img" loading="lazy">
            <div class="car-card-badges">
              {% if car.condition == 'New' %}<span class="badge badge-new">New</span>{% endif %}
              {% if car.import_country %}<span class="badge badge-import">{{ car.import_country }}</span>{% endif %}
            </div>
            <div class="car-card-fuel">{{ car.fuel_type }}</div>
          </div>
          <div class="car-card-body">
            <div class="car-card-year">{{ car.year }} · {{ car.transmission }}</div>
            <h3 class="car-card-title">{{ car.make }} {{ car.model }}</h3>
            <div class="car-card-specs">
              <span>{{ "{:,}".format(car.mileage) }} km</span>
              <span>{{ car.body_type }}</span>
              {% if car.engine_cc %}<span>{{ car.engine_cc }}cc</span>{% endif %}
            </div>
            <div class="car-card-footer">
              <div class="car-card-price">KES {{ "{:,}".format(car.price) }}</div>
              <div class="car-card-cta">View →</div>
            </div>
          </div>
        </a>
        {% endfor %}
      </div>

      <!-- PAGINATION -->
      {% if cars.pages > 1 %}
      <div class="pagination">
        {% if cars.has_prev %}
        <a href="{{ url_for('inventory', page=cars.prev_num, make=filters.make, body_type=filters.body_type, fuel_type=filters.fuel_type, transmission=filters.transmission, max_price=filters.max_price, min_year=filters.min_year, sort=filters.sort) }}" class="page-btn">← Prev</a>
        {% endif %}
        {% for p in cars.iter_pages(left_edge=1, right_edge=1, left_current=2, right_current=2) %}
          {% if p %}
          <a href="{{ url_for('inventory', page=p, make=filters.make, body_type=filters.body_type, fuel_type=filters.fuel_type, transmission=filters.transmission, max_price=filters.max_price, min_year=filters.min_year, sort=filters.sort) }}"
             class="page-btn {% if p == cars.page %}page-active{% endif %}">{{ p }}</a>
          {% else %}
          <span class="page-ellipsis">…</span>
          {% endif %}
        {% endfor %}
        {% if cars.has_next %}
        <a href="{{ url_for('inventory', page=cars.next_num, make=filters.make, body_type=filters.body_type, fuel_type=filters.fuel_type, transmission=filters.transmission, max_price=filters.max_price, min_year=filters.min_year, sort=filters.sort) }}" class="page-btn">Next →</a>
        {% endif %}
      </div>
      {% endif %}

      {% else %}
      <div class="empty-state">
        <div class="empty-icon">🚗</div>
        <h3>No vehicles match your filters</h3>
        <p>Try adjusting your search criteria or browse our full inventory.</p>
        <a href="{{ url_for('inventory') }}" class="btn btn-primary">Clear Filters</a>
      </div>
      {% endif %}
    </main>
  </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
// ── ERROR TOAST ──
const ERROR_MESSAGES = {
  network: { title: 'Connection Error', msg: 'Unable to reach the server. Check your internet connection and try again.' },
  server:  { title: 'Server Error (500)', msg: 'Something went wrong on our end. Please try again in a moment.' },
  ratelimit: { title: 'Too Many Requests (429)', msg: 'You\'ve made too many requests. Please wait a minute before trying again.' },
  notfound: { title: 'Not Found (404)', msg: 'The page or resource you requested could not be found.' },
  timeout: { title: 'Request Timed Out', msg: 'The server took too long to respond. Please try again.' },
};

function showError(type, customMsg) {
  const existing = document.getElementById('errorToast');
  if (existing) existing.remove();
  const e = ERROR_MESSAGES[type] || { title: 'Error', msg: customMsg || 'An unexpected error occurred.' };
  const toast = document.createElement('div');
  toast.className = 'error-toast';
  toast.id = 'errorToast';
  toast.innerHTML = `
    <div class="error-toast-icon">⚠️</div>
    <div class="error-toast-body">
      <div class="error-toast-title">${e.title}</div>
      <div class="error-toast-msg">${e.msg}</div>
    </div>
    <button class="error-toast-close" onclick="this.closest('.error-toast').remove()">×</button>
  `;
  document.body.appendChild(toast);
  requestAnimationFrame(() => toast.classList.add('show'));
  setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 300); }, 5000);
}

// ── SKELETON ──
function buildSkeletonGrid(count) {
  let html = '<div class="car-grid-skeleton" id="skeletonGrid">';
  for (let i = 0; i < count; i++) {
    html += `
      <div class="skeleton-card">
        <div class="skeleton skeleton-img"></div>
        <div class="skeleton-body">
          <div class="skeleton skeleton-line short"></div>
          <div class="skeleton skeleton-line medium"></div>
          <div class="skeleton skeleton-line long"></div>
          <div class="skeleton skeleton-line short"></div>
          <div class="skeleton skeleton-price"></div>
        </div>
      </div>`;
  }
  html += '</div>';
  return html;
}

function simulateSkeleton() {
  const grid = document.querySelector('.car-grid');
  if (!grid) return;
  const real = grid.outerHTML;
  grid.outerHTML = buildSkeletonGrid(9);
  setTimeout(() => {
    const skeleton = document.getElementById('skeletonGrid');
    if (skeleton) skeleton.outerHTML = real;
  }, 2500);
}

// ── INTERCEPT FETCH ERRORS ──
const originalFetch = window.fetch;
window.fetch = async function(...args) {
  try {
    const res = await originalFetch(...args);
    if (res.status === 429) showError('ratelimit');
    else if (res.status === 404) showError('notfound');
    else if (res.status >= 500) showError('server');
    return res;
  } catch(err) {
    showError('network');
    throw err;
  }
};
</script>
{% endblock %}

